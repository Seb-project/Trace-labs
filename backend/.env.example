OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-5.5
OPENAI_TIMEOUT_SECONDS=20
OPENAI_DATASHEET_TIMEOUT_SECONDS=180
OPENAI_DATASHEET_MAX_OUTPUT_TOKENS=8000
DATASHEET_LIVE_SEARCH_ENABLED=true
PCBSTREAM_LCSC_LOOKUP_ENABLED=true
PCBSTREAM_LCSC_LOOKUP_TIMEOUT_SECONDS=90
PCBSTREAM_ONLINE_LIBRARY_LOOKUP_ENABLED=true
PCBSTREAM_ONLINE_SYMBOL_IMPORT_ENABLED=false
PCBSTREAM_SUPPLIER_SYMBOL_IMPORT_ENABLED=false
