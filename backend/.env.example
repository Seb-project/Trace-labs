OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-5.5
OPENAI_TIMEOUT_SECONDS=20
OPENAI_DATASHEET_TIMEOUT_SECONDS=60
OPENAI_BROAD_DATASHEET_TIMEOUT_SECONDS=20
OPENAI_DATASHEET_MAX_OUTPUT_TOKENS=8000
DATASHEET_LIVE_SEARCH_ENABLED=true
TRACELABS_SOURCE_FETCH_TIMEOUT_SECONDS=15
TRACELABS_LCSC_LOOKUP_ENABLED=true
TRACELABS_LCSC_LOOKUP_TIMEOUT_SECONDS=90
TRACELABS_ONLINE_LIBRARY_LOOKUP_ENABLED=true
TRACELABS_ONLINE_SYMBOL_IMPORT_ENABLED=false
TRACELABS_SUPPLIER_SYMBOL_IMPORT_ENABLED=false

# Optional local account metadata shown in the account menu.
TRACELABS_ACCOUNT_ID=local-dev
TRACELABS_ACCOUNT_NAME=Local developer
TRACELABS_ACCOUNT_EMAIL=

# Optional Solvimon billing sync. Leave unset for local-only usage metering.
SOLVIMON_ENVIRONMENT=test
SOLVIMON_API_KEY=
SOLVIMON_CUSTOMER_REFERENCE=
SOLVIMON_SUBSCRIPTION_REFERENCE=
SOLVIMON_CIRCUIT_BLOCK_METER_REFERENCE=
SOLVIMON_KICAD_EXPORT_METER_REFERENCE=
SOLVIMON_DATASHEET_PAGE_METER_REFERENCE=
SOLVIMON_AI_TOKEN_METER_REFERENCE=
SOLVIMON_FOOTPRINT_LOOKUP_METER_REFERENCE=
SOLVIMON_METER_VALUE_REFERENCE=quantity
SOLVIMON_TIMEOUT_SECONDS=8
