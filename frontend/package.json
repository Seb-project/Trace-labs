{
  "name": "tracelabs-desktop",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5173",
    "electron": "electron electron/main.cjs",
    "start": "concurrently -k \"npm run dev\" \"wait-on http://127.0.0.1:5173 && npm run electron\"",
    "fix:electron": "node scripts/repair-electron.cjs",
    "postinstall": "node scripts/patch-electron-name.cjs",
    "build": "tsc && vite build",
    "build:backend": "node ../packaging/run-pyinstaller.cjs",
    "prepare:demo-env": "node scripts/prepare-demo-env.cjs",
    "pack:dir": "npm run build && npm run build:backend && npm run prepare:demo-env && electron-builder --dir",
    "dist:mac": "node ../packaging/assert-platform.cjs darwin && npm run build && npm run build:backend && npm run prepare:demo-env && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg zip",
    "dist:win": "node ../packaging/assert-platform.cjs win32 && npm run build && npm run build:backend && npm run prepare:demo-env && electron-builder --win nsis zip --x64",
    "dist:judge:mac": "npm run dist:mac",
    "dist:judge:win": "npm run dist:win",
    "dist": "npm run dist:mac",
    "test": "vitest run --environment jsdom"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^15.0.7",
    "@types/react": "^18.2.79",
    "@types/react-dom": "^18.2.25",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^30.5.1",
    "electron-builder": "^26.15.3",
    "jsdom": "^24.1.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "vitest": "^1.6.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.tracelabs.desktop",
    "productName": "Trace Labs",
    "icon": "build/icon",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "build/**/*",
      "package.json",
      "logo.svg"
    ],
    "extraResources": [
      {
        "from": "../dist",
        "to": "backend",
        "filter": [
          "tracelabs-backend*"
        ]
      },
      {
        "from": "../dist/demo",
        "to": "demo",
        "filter": [
          "backend.env"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "artifactName": "${productName}-${version}-${arch}-windows.${ext}",
      "target": [
        "nsis",
        "zip"
      ],
      "verifyUpdateCodeSignature": false
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Development"
    }
  }
}
